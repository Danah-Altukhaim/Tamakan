# Google Gemini API key for the AI assistant (free tier: aistudio.google.com/apikey)
# Copy this file to .env and fill in your key. Without a key, the assistant
# falls back to a keyword-only stub (no LLM, still functional).
GEMINI_API_KEY=
# Optional — defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
