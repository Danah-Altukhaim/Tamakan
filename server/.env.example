# Google Gemini API key for the AI assistant (free tier: aistudio.google.com/apikey)
# Copy this file to .env and fill in your key. Without a key, the assistant
# falls back to a keyword-only stub (no LLM, still functional).
GEMINI_API_KEY=
# Optional — defaults to gemini-2.5-flash. May be a comma-separated fallback
# chain, e.g. gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Groq API key — Nassour's fallback LLM when Gemini is quota-throttled
# (free tier: console.groq.com/keys). Far more generous daily limits than
# Gemini's free tier, so the assistant keeps answering instead of deflecting.
GROQ_API_KEY=
# Optional — defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
